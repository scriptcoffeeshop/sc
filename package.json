{
  "private": true,
  "scripts": {
    "dev": "vite --config frontend/vite.config.js",
    "build": "vite build --config frontend/vite.config.js && bash scripts/prepare_static_deploy.sh",
    "preview": "vite preview --config frontend/vite.config.js",
    "preview:e2e": "bash scripts/serve_e2e_preview.sh",
    "hygiene": "python3 scripts/repo_hygiene_check.py",
    "fmt": "cd supabase/functions/coffee-api && deno fmt .",
    "fmt:check": "cd supabase/functions/coffee-api && deno fmt --check .",
    "lint": "cd supabase/functions/coffee-api && deno lint .",
    "check": "cd supabase/functions/coffee-api && deno check index.ts",
    "test": "cd supabase/functions/coffee-api && JWT_SECRET=mock SUPABASE_URL=https://mock.supabase.co SUPABASE_SERVICE_ROLE_KEY=mock deno test --allow-env --allow-net --allow-read tests/",
    "test:unit": "vitest run --config frontend/vite.config.js",
    "e2e": "npx playwright test --config=playwright.config.ts",
    "e2e:smoke": "npx playwright test tests/e2e/smoke --config=playwright.config.ts",
    "guardrails": "python3 scripts/repo_hygiene_check.py && python3 scripts/check_migration_names.py && python3 scripts/check_new_composables_ts.py && python3 scripts/check_dashboard_event_delegation.py && python3 scripts/check_main_event_delegation.py && python3 scripts/sync_frontend_version.py --check",
    "ci-local": "npm run guardrails && npm run test:unit && npm run fmt:check && npm run lint && npm run check && npm run test",
    "health": "npm run ci-local && npm run build && SKIP_E2E_BUILD=1 npm run e2e",
    "deploy": "bash scripts/supabase_deploy.sh",
    "supabase:deploy": "bash scripts/supabase_deploy.sh",
    "supabase:db:push": "bash scripts/supabase_db_push.sh",
    "serve": "vite preview --config frontend/vite.config.js --host 0.0.0.0 --port 5500"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.9.3",
    "sortablejs": "^1.15.2",
    "sweetalert2": "^11.10.6",
    "tailwind-merge": "^3.5.0",
    "tw-city-selector": "^2.1.2",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@types/deno": "latest",
    "@vitejs/plugin-vue": "^6.0.4",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.1",
    "vitest": "^4.1.4"
  }
}
