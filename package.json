{
  "private": true,
  "scripts": {
    "fmt": "cd supabase/functions/coffee-api && deno fmt .",
    "fmt:check": "cd supabase/functions/coffee-api && deno fmt --check .",
    "lint": "cd supabase/functions/coffee-api && deno lint .",
    "check": "cd supabase/functions/coffee-api && deno check index.ts",
    "test": "cd supabase/functions/coffee-api && deno test --allow-all tests/",
    "e2e": "npx playwright test tests/e2e/smoke.spec.ts --config=playwright.config.ts",
    "guardrails": "python3 scripts/check_dashboard_event_delegation.py && python3 scripts/check_main_event_delegation.py && python3 scripts/sync_frontend_version.py --check",
    "ci-local": "npm run guardrails && npm run fmt:check && npm run lint && npm run check && npm run test",
    "deploy": "supabase functions deploy coffee-api --no-verify-jwt",
    "serve": "python3 -m http.server 5500"
  },
  "dependencies": {
    "@playwright/test": "^1.53.2"
  }
}
