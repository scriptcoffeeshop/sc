{
  "private": true,
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "build": "vite build --config frontend/vite.config.ts && bash scripts/prepare_static_deploy.sh",
    "preview": "vite preview --config frontend/vite.config.ts",
    "preview:e2e": "bash scripts/serve_e2e_preview.sh",
    "hygiene": "python3 scripts/repo_hygiene_check.py",
    "fmt": "cd supabase/functions/coffee-api && deno fmt .",
    "fmt:check": "cd supabase/functions/coffee-api && deno fmt --check .",
    "lint:frontend": "eslint \"frontend/src/**/*.{ts,vue}\"",
    "lint": "cd supabase/functions/coffee-api && deno lint .",
    "check": "cd supabase/functions/coffee-api && deno check index.ts",
    "test": "cd supabase/functions/coffee-api && JWT_SECRET=mock SUPABASE_URL=https://mock.supabase.co SUPABASE_SERVICE_ROLE_KEY=mock deno test --allow-env --allow-net --allow-read tests/",
    "test:integration:supabase": "bash scripts/run_supabase_integration_test.sh",
    "test:unit": "vitest run --config frontend/vite.config.ts",
    "typecheck": "vue-tsc --noEmit -p frontend/tsconfig.json",
    "typecheck:full": "vue-tsc --noEmit -p frontend/tsconfig.json",
    "e2e": "npx playwright test --config=playwright.config.ts",
    "e2e:smoke": "npx playwright test tests/e2e/smoke --config=playwright.config.ts",
    "guardrails": "python3 scripts/repo_hygiene_check.py && python3 scripts/check_migration_names.py && python3 scripts/check_order_status_schema.py && python3 scripts/check_dashboard_event_delegation.py && python3 scripts/check_main_event_delegation.py && python3 scripts/sync_frontend_version.py --check && python3 scripts/check_dev_context_sync.py",
    "ci-local": "npm run guardrails && npm run typecheck && npm run lint:frontend && npm run test:unit && npm run fmt:check && npm run lint && npm run check && npm run test",
    "health": "npm run ci-local && npm run build && SKIP_E2E_BUILD=1 npm run e2e",
    "deploy": "bash scripts/supabase_deploy.sh",
    "supabase:deploy": "bash scripts/supabase_deploy.sh",
    "supabase:db:push": "bash scripts/supabase_db_push.sh",
    "serve": "vite preview --config frontend/vite.config.ts --host 0.0.0.0 --port 5500"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.9.6",
    "sortablejs": "^1.15.7",
    "sweetalert2": "^11.26.24",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.53.2",
    "@types/deno": "latest",
    "@types/node": "^20.19.0",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.8",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.36.0",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript-eslint": "^8.44.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.7"
  }
}
