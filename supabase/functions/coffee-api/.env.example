# Supabase Secrets Example
# 使用命令設定：supabase secrets set --env-file .env.staging

SUPABASE_URL=your_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

JWT_SECRET=your_jwt_secret
LINE_ADMIN_USER_ID=your_id

LINEPAY_CHANNEL_ID=...
LINEPAY_CHANNEL_SECRET=...

ECPAY_MERCHANT_ID=...
ECPAY_HASH_KEY=...
ECPAY_HASH_IV=...
ECPAY_IS_STAGE=true

JKOPAY_STORE_ID=...
JKOPAY_API_KEY=...
JKOPAY_SECRET_KEY=...
JKOPAY_BASE_URL=https://onlinepay.jkopay.com
JKOPAY_PROXY_URL=

SMTP_USER=...
SMTP_PASS=...

LINE_LOGIN_CHANNEL_ID=...
LINE_LOGIN_CHANNEL_SECRET=...

FRONTEND_URL=https://your-staging-frontend.com
ALLOWED_REDIRECT_ORIGINS=http://localhost:5500,https://your-staging-frontend.com
