# 請複製為 `.env.staging` 後填入真實值，本檔不可存放正式金鑰。
LINE_LOGIN_CHANNEL_ID=your_line_login_channel_id
LINE_LOGIN_CHANNEL_SECRET=your_line_login_channel_secret
LINEPAY_CHANNEL_ID=your_linepay_channel_id
LINEPAY_CHANNEL_SECRET=your_linepay_channel_secret
SMTP_USER=mailer@example.com
SMTP_PASS=replace_with_smtp_password
ECPAY_MERCHANT_ID=your_ecpay_merchant_id
ECPAY_HASH_KEY=replace_with_ecpay_hash_key
ECPAY_HASH_IV=replace_with_ecpay_hash_iv
ECPAY_IS_STAGE=true
JKOPAY_STORE_ID=your_jkopay_store_id
JKOPAY_API_KEY=your_jkopay_api_key
JKOPAY_SECRET_KEY=replace_with_jkopay_secret_key
JKOPAY_BASE_URL=https://onlinepay.jkopay.com
JKOPAY_PROXY_URL=
LINE_ADMIN_USER_ID=your_line_admin_user_id
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=your_line_messaging_channel_access_token
LINE_ORDER_NOTIFY_CHANNEL_ACCESS_TOKEN=your_order_notify_channel_access_token
LINE_ORDER_NOTIFY_TO=comma_or_newline_separated_line_user_or_group_ids
JWT_SECRET=replace_with_strong_random_string
FRONTEND_URL=https://your-domain.example
ALLOWED_REDIRECT_ORIGINS=https://your-domain.example,http://localhost:4173
